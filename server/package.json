{
  "name": "simple-theory-server",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#db/*": "./db/*.js",
    "#middleware/*": "./middleware/*.js",
    "#utils/*": "./utils/*.js",
    "#api/*": "./api/*.js",
    "#app": "./app.js"
  },
  "scripts": {
    "start": "node --env-file=.env index.js",
    "dev": "tsx watch --env-file=.env index.js",
    "db:schema": "psql -d simple_theory -f db/schema.sql",
    "db:seed": "node --env-file=.env db/seed.js",
    "db:reset": "npm run db:schema && npm run db:seed"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
